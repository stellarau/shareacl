<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Account view" FontFamily="Segoe UI" FontSize="12">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar: principal picker + filters -->
        <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Button   x:Name="BtnPickPrincipal" Content="Pick principal…" Padding="10,4"/>
                <TextBlock x:Name="TxtPrincipalName"
                           Text="(none selected)" VerticalAlignment="Center"
                           Margin="12,0,0,0" FontWeight="Bold"/>
                <TextBlock x:Name="TxtPrincipalType"
                           Text="" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="#666"/>
                <Separator Width="1" Margin="14,2" Background="#CCC"/>
                <TextBlock Text="Path contains:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox   x:Name="TxtPathFilter" Width="260" VerticalAlignment="Center"/>
                <CheckBox  x:Name="ChkAllowOnly"   Content="Allow only"        VerticalAlignment="Center" Margin="12,0,0,0"/>
                <CheckBox  x:Name="ChkExplicitOnly" Content="Explicit ACEs only" VerticalAlignment="Center" Margin="12,0,0,0"/>
                <Button    x:Name="BtnRefresh"    Content="Refresh"   Margin="12,0,0,0"/>
                <Button    x:Name="BtnExportCsv"  Content="Export CSV…" Margin="6,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Results: reachable folders + a "via" pane -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="GrdReachable" Grid.Column="0"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" CanUserAddRows="False"
                      GridLinesVisibility="Horizontal" RowHeaderWidth="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Path"     Binding="{Binding Path}"     Width="*"/>
                    <DataGridTextColumn Header="Rights"   Binding="{Binding Rights}"   Width="220"/>
                    <DataGridTextColumn Header="Type"     Binding="{Binding AceType}"  Width="50"/>
                    <DataGridTextColumn Header="Inh"      Binding="{Binding Inherited}" Width="40"/>
                    <DataGridTextColumn Header="Via"      Binding="{Binding ViaSummary}" Width="260"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#DDD"/>

            <DockPanel Grid.Column="2" Margin="6,0,0,0">
                <TextBlock DockPanel.Dock="Top" Text="Membership chain" FontWeight="Bold" Margin="0,0,0,4"/>
                <Button   DockPanel.Dock="Bottom" x:Name="BtnLiveEffective"
                          Content="Live effective access (Get-NTFSEffectiveAccess)"
                          Margin="0,6,0,0" Padding="8,4" IsEnabled="False"/>
                <TextBlock DockPanel.Dock="Bottom" x:Name="TxtEffectiveResult"
                           TextWrapping="Wrap" Margin="0,6,0,0" Foreground="#444"/>
                <ListBox  x:Name="LstVia"/>
            </DockPanel>
        </Grid>
    </Grid>
</Page>