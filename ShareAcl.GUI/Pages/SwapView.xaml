<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ACL Swap" FontFamily="Segoe UI" FontSize="12">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. Inputs -->
        <Border Grid.Row="0" Background="#F8F8F8" BorderBrush="#DDD" BorderThickness="1" Padding="10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Source principal:" VerticalAlignment="Center" Margin="0,2,8,2"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtSource"
                           Text="(not set)" VerticalAlignment="Center" FontWeight="Bold" Margin="0,2"/>
                <Button    Grid.Row="0" Grid.Column="2" x:Name="BtnPickSource" Content="Pick…" Padding="10,2" Margin="0,2"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Target principal:" VerticalAlignment="Center" Margin="0,2,8,2"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtTarget"
                           Text="(not set)" VerticalAlignment="Center" FontWeight="Bold" Margin="0,2"/>
                <Button    Grid.Row="1" Grid.Column="2" x:Name="BtnPickTarget" Content="Pick…" Padding="10,2" Margin="0,2"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Scope (path):" VerticalAlignment="Center" Margin="0,2,8,2"/>
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtScope" Margin="0,2"
                           ToolTip="UNC or local path. The substitution recurses into every subfolder under this root."/>
                <Button    Grid.Row="2" Grid.Column="2" x:Name="BtnBrowseScope" Content="Browse…" Padding="10,2" Margin="0,2"/>

                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,6,0,0">
                    <CheckBox x:Name="ChkIncludeFiles"  Content="Include files (not just folders)" Margin="0,0,16,0"/>
                    <CheckBox x:Name="ChkSkipReparse"   Content="Skip reparse points / junctions" IsChecked="True" Margin="0,0,16,0"/>
                    <CheckBox x:Name="ChkOverrideGuard" Content="Allow well-known SID as source (DANGEROUS)" Foreground="#C00"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. Action buttons -->
        <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" Padding="10" Margin="0,0,0,8">
            <StackPanel>
                <!-- Row 1: discovery mode + preview -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Discover affected folders:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <RadioButton x:Name="RbModeScan" Content="From loaded scan"
                                VerticalAlignment="Center" GroupName="DiscoveryMode" Margin="0,0,10,0"/>
                    <RadioButton x:Name="RbModeLive" Content="Live walk (queries the filesystem)"
                                VerticalAlignment="Center" GroupName="DiscoveryMode" Margin="0,0,14,0"/>
                    <Separator Width="1" Background="#CCC" Margin="0,2,14,2"/>
                    <Button x:Name="BtnPreview" Content="Preview (dry-run)" Padding="14,6" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtPreviewStatus" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#555"/>
                </StackPanel>
                <!-- Row 2: confirmation + execute + verify -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Type 'APPLY' to confirm:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="TxtConfirm" Width="100" VerticalAlignment="Center"/>
                    <Button x:Name="BtnExecute" Content="Execute" Padding="14,6" Margin="14,0,0,0"
                            IsEnabled="False" Background="#E74C3C" Foreground="White" FontWeight="Bold"/>
                    <Button x:Name="BtnVerify"  Content="Verify"  Padding="14,6" Margin="6,0,0,0" IsEnabled="False"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 3. Tabs: Preview / Execute log / Verify -->
        <TabControl Grid.Row="2">
            <TabItem Header="Preview">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" x:Name="TxtPreviewSummary" Margin="6"
                               TextWrapping="Wrap" Foreground="#444"/>
                    <DataGrid x:Name="GrdPreview" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" GridLinesVisibility="Horizontal" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Folder"        Binding="{Binding Path}"         Width="2*"/>
                            <DataGridTextColumn Header="Inh"           Binding="{Binding Inh}"          Width="40"/>
                            <DataGridTextColumn Header="ACE count"     Binding="{Binding AceCount}"     Width="80"/>
                            <DataGridTextColumn Header="Source ACEs"   Binding="{Binding SourceRights}" Width="3*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="Execute log">
                <DockPanel>
                    <ProgressBar DockPanel.Dock="Top" x:Name="PbExecute" Height="14" Margin="6"/>
                    <DataGrid x:Name="GrdExecute" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" GridLinesVisibility="Horizontal" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="When"   Binding="{Binding When}"   Width="160"/>
                            <DataGridTextColumn Header="Folder" Binding="{Binding Path}"   Width="*"/>
                            <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="80"/>
                            <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="380"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="Verify">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" x:Name="TxtVerifySummary" Margin="6" TextWrapping="Wrap"/>
                    <DataGrid x:Name="GrdVerify" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" GridLinesVisibility="Horizontal" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Folder"  Binding="{Binding Path}"        Width="*"/>
                            <DataGridTextColumn Header="Status"  Binding="{Binding Status}"      Width="120"/>
                            <DataGridTextColumn Header="Detail"  Binding="{Binding Detail}"      Width="500"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>

        <!-- 4. Status bar -->
        <Border Grid.Row="3" Background="#F3F3F3" Padding="8,4" Margin="0,8,0,0">
            <TextBlock x:Name="TxtStatus" Foreground="#555"/>
        </Border>
    </Grid>
</Page>