<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Folder view" FontFamily="Segoe UI" FontSize="12">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filter bar -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Path contains:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="TxtPathFilter" Width="350"/>
            <CheckBox x:Name="ChkBrokenOnly" Content="Broken inheritance only"
                      VerticalAlignment="Center" Margin="12,0"/>
            <CheckBox x:Name="ChkExplicitOnly" Content="Explicit ACEs only"
                      VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Button x:Name="BtnRefresh" Content="Refresh"/>
            <Button x:Name="BtnExportCsv" Content="Export CSV…" Margin="12,0,0,0"/>
        </StackPanel>

        <!-- Split: folders left, ACEs right -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="GrdFolders" Grid.Column="0"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" CanUserAddRows="False"
                      GridLinesVisibility="Horizontal" RowHeaderWidth="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Path"       Binding="{Binding Path}"     Width="*"/>
                    <DataGridTextColumn Header="Inh"        Binding="{Binding Inh}"      Width="40"/>
                    <DataGridTextColumn Header="Explicit"   Binding="{Binding Explicit}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#DDD"/>

            <DataGrid x:Name="GrdAces" Grid.Column="2"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" GridLinesVisibility="Horizontal" RowHeaderWidth="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Trustee"    Binding="{Binding Trustee}"  Width="200"/>
                    <DataGridTextColumn Header="Type"       Binding="{Binding AceType}"  Width="50"/>
                    <DataGridTextColumn Header="Rights"     Binding="{Binding Rights}"   Width="*"/>
                    <DataGridTextColumn Header="Inherited"  Binding="{Binding Inherited}" Width="70"/>
                    <DataGridTextColumn Header="From"       Binding="{Binding InheritedFrom}" Width="200"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Page>