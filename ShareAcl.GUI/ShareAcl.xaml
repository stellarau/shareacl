<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShareACL"
        Height="800" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="12">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin"  Value="4,0"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="StatusText">
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Top: DB selector + scan picker -->
        <Border DockPanel.Dock="Top" Background="#F3F3F3" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Database:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="TxtDbPath" Width="500" VerticalAlignment="Center"/>
                <Button  x:Name="BtnBrowseDb" Content="Browse…"/>
                <Button  x:Name="BtnOpenDb"   Content="Open"/>
                <Separator Margin="12,0" Width="1" Background="#CCC"/>
                <TextBlock Text="Scan:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="CmbScan" Width="380" VerticalAlignment="Center"
                          DisplayMemberPath="Display" SelectedValuePath="ScanId"/>
                <Button x:Name="BtnRefreshScans" Content="↻" ToolTip="Refresh scan list"/>
            </StackPanel>
        </Border>

        <!-- Bottom: status bar -->
        <Border DockPanel.Dock="Bottom" Background="#F3F3F3" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Grid.Column="0" Style="{StaticResource StatusText}" Text="Ready."/>
                <TextBlock x:Name="TxtDbInfo" Grid.Column="1" Style="{StaticResource StatusText}" Text=""/>
            </Grid>
        </Border>

        <!-- Left: navigation -->
        <Border DockPanel.Dock="Left" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="0,0,1,0" Width="180">
            <StackPanel Margin="6">
                <TextBlock Text="VIEWS" FontWeight="Bold" Foreground="#888" Margin="6,8,0,4"/>
                <Button x:Name="NavFolder"   Content="Folder view"   HorizontalContentAlignment="Left" Padding="10,6" Margin="0,2"/>
                <Button x:Name="NavAccount"  Content="Account view"  HorizontalContentAlignment="Left" Padding="10,6" Margin="0,2" IsEnabled="False"/>
                <Button x:Name="NavFindings" Content="Findings"      HorizontalContentAlignment="Left" Padding="10,6" Margin="0,2" IsEnabled="False"/>
                <TextBlock Text="ACTIONS" FontWeight="Bold" Foreground="#888" Margin="6,16,0,4"/>
                <Button x:Name="NavSwap"     Content="ACL Swap"      HorizontalContentAlignment="Left" Padding="10,6" Margin="0,2" IsEnabled="False"/>
                <Button x:Name="NavCollect"  Content="New scan…"     HorizontalContentAlignment="Left" Padding="10,6" Margin="0,2" IsEnabled="False"/>
            </StackPanel>
        </Border>

        <!-- Center: page host -->
        <Frame x:Name="PageHost" NavigationUIVisibility="Hidden" Background="White"/>

    </DockPanel>
</Window>