<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Run resolver"
        Height="540" Width="820"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" FontSize="12">
    <DockPanel Margin="10">

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnStart"  Content="Run resolver" Padding="16,6" FontWeight="Bold"/>
            <Button x:Name="BtnCancel" Content="Cancel"       Padding="16,6" Margin="6,0,0,0" IsEnabled="False"/>
            <Button x:Name="BtnClose"  Content="Close"        Padding="16,6" Margin="6,0,0,0" IsCancel="True"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Top">
            <TextBlock TextWrapping="Wrap" Foreground="#333">
                <Run FontWeight="Bold">Re-resolve AD principals and group memberships</Run> against the current database.
                <LineBreak/>
                Use this after AD changes (group edits, new users) if you don't want to run a full new scan.
                Existing principals and group_members entries will be updated or added as needed.
            </TextBlock>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="Scope:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <RadioButton x:Name="RbAllSids"  Content="All unresolved SIDs across the database"
                             VerticalAlignment="Center" GroupName="ResolverScope" IsChecked="True" Margin="0,0,12,0"/>
                <RadioButton x:Name="RbCurrentScan" Content="SIDs from current scan only"
                             VerticalAlignment="Center" GroupName="ResolverScope"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <CheckBox x:Name="ChkCheckpoint" Content="Checkpoint DB on completion"
                          IsChecked="True" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="TxtStatus" Foreground="#666" Margin="0,10,0,4" Text="Ready."
                       TextWrapping="Wrap"/>
            <Border x:Name="BorderProgress" BorderBrush="#DDD" BorderThickness="1"
                    Padding="10" Margin="0,4,0,8" Visibility="Collapsed">
                <StackPanel>
                    <ProgressBar x:Name="PbProgress" Height="18" Minimum="0" Maximum="100" Value="0"/>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtProgressLeft" Grid.Column="0" Foreground="#333"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="TxtProgressRight" Grid.Column="1" Foreground="#555"
                                   FontFamily="Consolas" Margin="12,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <GroupBox Header="Output">
            <TextBox x:Name="TxtOutput" IsReadOnly="True" AcceptsReturn="True"
                     TextWrapping="NoWrap" FontFamily="Consolas" FontSize="11"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     Background="#111" Foreground="#E0E0E0"/>
        </GroupBox>

    </DockPanel>
</Window>
